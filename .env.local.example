# Firebase Client (공개 키 - 브라우저에서 사용)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (서버 전용 - 절대 공개 금지)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google-calendar

# Token Encryption (AES-256-GCM)
# 생성: openssl rand -hex 32
GOOGLE_TOKEN_ENCRYPTION_KEY=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@your-domain.com

# hCaptcha (위젯 봇 방지)
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET=

# Rate Limit (Upstash Redis - 선택)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron Security
# 생성: openssl rand -hex 32
CRON_SECRET=
#
# ── 외부 Cron 설정 (MVP 기본 — cron-job.org) ─────────────────────────────
# Vercel Hobby 플랜은 Cron이 1일 1회로 제한되어 15분 간격이 불가능합니다.
# MVP는 cron-job.org(무료)에서 아래와 같이 설정하세요:
#
#   [1] 예약 만료 처리
#   URL   : https://your-domain.com/api/cron/expire-appointments
#   Method: GET
#   Schedule: */15 * * * *  (15분 간격)
#   Header: Authorization: Bearer <CRON_SECRET 값>
#
#   [2] 리마인더 이메일 (상담 24h/1h 전 자동 발송)
#   URL   : https://your-domain.com/api/cron/reminders
#   Method: GET
#   Schedule: */15 * * * *  (15분 간격)
#   Header: Authorization: Bearer <CRON_SECRET 값>
#
# Vercel Pro 사용 시 vercel.json 의 crons 설정을 활성화하면 됩니다.
# ─────────────────────────────────────────────────────────────────────────

# Appointment Config
APPOINTMENT_HOLD_HOURS=24

# App
NEXT_PUBLIC_BASE_URL=https://your-domain.com
